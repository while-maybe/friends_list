<%= form_with(model: friend) do |form| %>
  <% if friend.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(friend.errors.count, "error") %> prohibited this friend from being saved:</h2>

      <ul>
        <% friend.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-5 mb-3 input-group">
    <%# <%= form.label :first_name, style: "display: block", class: "form-label" %>
    <span class="input-group-text">First Name</span>
    <%= form.text_field :first_name, class: "form-control", placeholder: "First Name" %>
  </div>

  <div class="mb-3 input-group">
    <%# <%= form.label :last_name, style: "display: block", class: "form-label" %>
    <span class="input-group-text">Last Name</span>
    <%= form.text_field :last_name, class: "form-control", placeholder: "Last Name" %>
  </div class="mb-3">

  <div class="mb-3 input-group">
    <%# <%= form.label :email, style: "display: block", class: "form-label" %>
    <span class="input-group-text">Email</span>
    <%= form.text_field :email, class: "form-control", placeholder: "Email" %>
  </div>

  <div class="mb-3 input-group">
    <%# <%= form.label :phone, style: "display: block", class: "form-label" %>
    <span class="input-group-text">Phone number</span>
    <%= form.text_field :phone, class: "form-control", placeholder: "Phone number" %>
  </div>

  <div class="mb-3 input-group">
    <%# <%= form.label :twitter, style: "display: block", class: "form-label" %>
    <span class="input-group-text">Twitter</span>
    <%= form.text_field :twitter, class: "form-control", placeholder: "Twitter" %>
  </div>

  <div>
    <%= form.submit class:"btn btn-secondary mt-5" %>
  </div>
<% end %>
