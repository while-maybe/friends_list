<%#<p style="color: green"><%= notice %>
<%#</p>%>

<div class="position-relative p-5  text-muted bg-body border border-dashed rounded-5">
  <h1 class="text-body-emphasis">
    <%=@friend.first_name%> <%=@friend.last_name%>
  </h1>
  <p class="col-lg-6 mb-5 h5">

    <%# <%= render @friend %>

    <%= @friend.email %>  |  
    <%= @friend.phone %>  |  
    <%= @friend.twitter %>
  </p>

  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_friend_path(@friend), class:"btn btn-secondary" %>
    <%= link_to "Delete", @friend, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class:"btn btn-danger" %>
    <%= link_to "Back to friends", friends_path, class:"btn btn-secondary" %>
  </div>
</div>
