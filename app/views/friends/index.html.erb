<%# <p style="color: green"><%= notice %>
<%# </p> %>

<% if !user_signed_in? %>

  <h1>Hello World</h1>
  <p>Find me in app/views/home/index.html.erb</p>
  <p>this is a line I added myself</p>

<% else %>

  <% content_for :title, "Friends" %>

  <h1 class="d-none">Friend List</h1>

  <div id="friends">
    <table class="table table-striped table-bordered table-hover">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Twitter</th>
          <%# <th>user_id</th> %>
          <%# <th colspan="2">Actions</th> <!-- For Show, Edit, Destroy links --> %>
          <th></th>
        </tr>
      </thead>

      <tbody>
        <% @friends.each do |friend| %>
          <% if friend.user != current_user %>
            <% next %>
          <% end %>
          <tr>
            <td>
              <%= link_to friend.first_name + " " + friend.last_name, friend %>
            </td>
            
            <td><%= friend.email %></td>
            <td><%= friend.phone %></td>
            <td><%= friend.twitter %></td>
            <%# <td><%= friend.user_id %><%#</td> %>
            <%# <td><%= link_to "Show", friend %><%#</td> %>
            <%# <td><%= link_to "Edit", edit_friend_path(friend) %><%#</td> %>
            <td><%= link_to "Delete", friend, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class:"btn btn-outline-danger btn-sm" %></td>
            
            <%# Adjust the Edit/Destroy links/paths if needed %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= link_to "New friend", new_friend_path, class:"btn btn-secondary" %>
<% end %>